# === LLM Providers ===
OPENROUTER_API_KEY=sk-or-v1-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=xxx
# GEMINI_API_KEY=xxx

# === Search (optional) ===
# BRAVE_SEARCH_API_KEY=xxx

# === Channels (fill what you use) ===
# TELEGRAM_BOT_TOKEN=xxx
# TELEGRAM_ALLOW_FROM=your_user_id
# DISCORD_BOT_TOKEN=xxx
# DISCORD_ALLOW_FROM=your_user_id

# === Model Config ===
NANOBOT_MODEL=anthropic/claude-opus-4-5
NANOBOT_PROVIDER=openrouter

# === VPS Deployment ===
DEPLOY_HOST=your-vps-ip
DEPLOY_USER=root
DEPLOY_PATH=/opt/nanogents
